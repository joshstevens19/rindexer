int(&cache, &mock, 100).await;\n    assert_eq!(fork, 98); // oldest checked block, no match found\n}\n```\n\n- [ ] **Step 5: Run all fork point tests**\n\nRun: `cargo nextest run -p rindexer find_fork_point`\nExpected: ALL PASS\n\n- [ ] **Step 6: Commit**\n\n```bash\ngit add core/src/indexer/reorg.rs\ngit commit -m \"test: cover find_fork_point with matching, empty, and mismatch cases\"\n```\n\n---\n\n### Task 5: Test `retry_with_block_range` (RPC error message parsing)\n\nAsync function at `core/src/indexer/fetch_logs.rs:959`. Currently zero test coverage. This is pure logic that parses RPC provider error messages to extract suggested block ranges. High-value coverage target.\n\n**Files:**\n- Modify: `core/src/indexer/fetch_logs.rs` (add tests to existing test module)\n\n- [ ] **Step 1: Write Alchemy error parsing test**\n\n```rust\n#[tokio::test]\nasync fn retry_parses_alchemy_block_range() {\n    use alloy::transports::RpcError;\n    use alloy::json_abi;\n\n    let err = ProviderError::CustomError(\n        \"this block range should work: [0x100, 0x200]\".to_string(),\n    );\n    // retry_with_block_range checks error_struct first (None for CustomError),\n    // then falls through to string matching\n    let result = retry_with_block_range(\n        \"test\",\n        &err,\n        U64::from(100),\n        U64::from(1000),\n        None,\n    )\n    .await;\n\n    let r = result.expect(\"should parse alchemy range\");\n    assert_eq!(r.from, U64::from(0x100));\n    assert_eq!(r.to, U64::from(0x200));\n}\n```\n\n- [ ] **Step 2: Write Ankr \"block range too wide\" test**\n\n```rust\n#[tokio::test]\nasync fn retry_handles_ankr_block_range_too_wide() {\n    let err = ProviderError::CustomError(\"block range is too wide\".to_string());\n    let result = retry_with_block_range(\n        \"test\",\n        &err,\n        U64::from(100),\n        U64::from(10000),\n        None,\n    )\n    .await;\n\n    let r = result.expect(\"should handle ankr error\");\n    assert