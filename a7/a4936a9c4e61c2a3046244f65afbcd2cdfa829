test (no pattern match, generic error)**\n\n```rust\n#[tokio::test]\nasync fn retry_uses_fallback_range_for_unknown_error() {\n    let err = ProviderError::CustomError(\"some unknown rpc error\".to_string());\n    let result = retry_with_block_range(\n        \"test\",\n        &err,\n        U64::from(100),\n        U64::from(10100),\n        None,\n    )\n    .await;\n\n    let r = result.expect(\"should compute fallback range\");\n    assert_eq!(r.from, U64::from(100));\n    // diff = 10000, FallbackBlockRange::from_diff(10000) = Range5000\n    assert_eq!(r.to, U64::from(100) + U64::from(5000));\n}\n```\n\n- [ ] **Step 7: Write test for equal from/to returning None**\n\n```rust\n#[tokio::test]\nasync fn retry_returns_none_when_from_equals_to() {\n    let err = ProviderError::CustomError(\"some unknown error\".to_string());\n    let result = retry_with_block_range(\n        \"test\",\n        &err,\n        U64::from(100),\n        U64::from(100),\n        None,\n    )\n    .await;\n    assert!(result.is_none());\n}\n```\n\n- [ ] **Step 8: Run all retry tests**\n\nRun: `cargo nextest run -p rindexer retry_`\nExpected: ALL PASS\n\n- [ ] **Step 9: Commit**\n\n```bash\ngit add core/src/indexer/fetch_logs.rs\ngit commit -m \"test: cover retry_with_block_range for all RPC provider error patterns\"\n```\n\n---\n\n### Task 6: Test `provider_trace_call` dispatch\n\nSimple async dispatch function at `core/src/indexer/native_transfer.rs:369`. Tests that `TraceBlock` and `DebugTraceBlockByNumber` methods dispatch to the correct provider method.\n\n**Files:**\n- Modify: `core/src/indexer/native_transfer.rs` (add tests to existing test module)\n\n- [ ] **Step 1: Write tests**\n\n```rust\n#[tokio::test]\nasync fn provider_trace_call_dispatches_trace_block() {\n    use alloy::rpc::types::trace::parity::{\n        Action, CallAction, LocalizedTransactionTrace, TraceOutput, TransactionTrace,\n    };\n\n    let trace = LocalizedTransactionTrace {\n        trace: TransactionTrace {\n            action: Action::Call(CallAction {\n                from: Address::ZERO,\n                to: Address::ZERO,\n                value: U256::ZERO,\n                gas: 0,\n                input: Bytes::new(),\n                call_type: alloy::rpc::types::trace::parity::CallType::Call,\n            }),\n            error: None,\n            result: Some(TraceOutput::Call(alloy::rpc::types::trace::parity::CallOutput {\n                gas_used: 0,\n                output: Bytes::new(),\n            })),\n            subtraces: 0,\n            trace_address: vec![],\n        },\n        transaction_hash: None,\n        transaction_position: None,\n        block_hash: None,\n        block_number: None,\n    };\n\n    let mock = Arc::new(MockChainProvider::new(1).with_traces(vec![trace]));\n\n    // Build a minimal TraceProcessingConfig\n    // The key field is `method`\n    let config = TraceProcessingConfig::test_config(TraceProcessingMethod::TraceBlock);\n\n    let result = provider_trace_call(mock.clone(), &config, U64::from(100)).await;\n    assert!(result.is_ok());\n    assert_eq!(result.unwrap().len(), 1);\n}\n```\n\nNote: This test may require `TraceProcessingConfig` to have a test constructor or be constructible in tests. If `TraceProcessingConfig` fields are not public, you'll need to check its definition and either add a `#[cfg(test)]` constructor or access it differently. Check `core/src/event/config.rs` for the struct definition first.\n\n- [ ] **Step 2: Run test**\n\nRun: `cargo nextest run -p rindexer provider_trace_call_dispatches`\nExpected: PASS (or may need adjustments based on TraceProcessingConfig construction)\n\n- [ ] **Step 3: Commit**\n\n```bash\ngit add core/src/indexer/native_transfer.rs\ngit commit -m \"test: cover provider_trace_call dispatch\"\n```\n\n---\n\n### Task 7: Test `spawn_post_confirmation_verifier`\n\nAsync spawned task at `core/src/indexer/reorg.rs:1327`. Uses `Arc<dyn ChainProvider>`. Tests that it detects hash mismatches and sends `ReorgInfo`.\n\n**Files:**\n- Modify: `core/src/indexer/reorg.rs` (add tests to existing test module)\n\n- [ ] **Step 1: Write test for mismatch detection**\n\n```rust\nuse crate::provider::mock::MockChainProvider;\nuse tokio_util::sync::CancellationToken;\n\n#[tokio::test]\nasync fn post_confirmation_verifier_detects_mismatch() {\n    use alloy::consensus::Header;\n    use alloy::rpc::types::Block;\n\n    let cached_hash = B256::from([0xAA; 32]);\n    let canonical_hash = B256::from([0xBB; 32]); // different!\n\n    // Provider returns block 100 with canonical_hash, and block_number = 200\n    // so verify_up_to = 200 - 5 = 195, block 100 qualifies\n    let canonical_block = AnyRpcBlock::from(Block {\n        header: Header { number: 100, ..Default::default() }\n            .seal(canonical_hash),\n        ..Default::default()\n    });\n\n    let mock = Arc::new(\n        MockChainProvider::new(1)\n            .with_block_number(200)\n            .with_blocks(vec![canonical_block.clone().into()]),\n    );\n\n    let shadow = new_shadow_cache();\n    {\n        let mut c = shadow.lock().unwrap();\n        c.insert(100, cached_hash); // cached hash differs from canonical\n    }\n\n    let (reorg_tx, mut reorg_rx) = tokio::sync::mpsc::unbounded_channel::<ReorgInfo>();\n    let cancel = CancellationToken::new();\n\n    let _handle = spawn_post_confirmation_verifier(\n        shadow.clone(),\n        mock,\n        5, // low confirmations for test\n        reorg_tx,\n        cancel.clone(),\n        \"test\".to_string(),\n    );\n\n    // Wait for the verifier to detect the mismatch (check interval is 30s in prod,\n    // but for tests we need to wait or use tokio::time::pause)\n    // Use tokio::time to advance past the 30s interval\n    tokio::time::pause();\n    tokio::time::advance(std::time::Duration::from_secs(31)).await;\n    tokio::task::yield_now().await;\n\n    let reorg = tokio::time::timeout(std::time::Duration::from_secs(5), reorg_rx.recv())\