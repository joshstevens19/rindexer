ame, value, block_number, tx_index, log_index) \\\n                 VALUES ('{}', '{}', '{}', '{}', {}, {}, {}, {})\",\n                derived_table,\n                row.network,\n                where_key.replace('\\'', \"''\"),\n                sc.column,\n                value_str,\n                block_number,\n                tx_index,\n                log_index,\n            );\n\n            if let Err(e) = postgres.batch_execute(&sql).await {\n                tracing::error!(\n                    table = %derived_table,\n                    column = %sc.column,\n                    \"Failed to journal non-reversible op: {:?}\",\n                    e\n                );\n            }\n        }\n    }\n}\n\n#[cfg(test)]\nmod tests {",
